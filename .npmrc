# ==============================================================================
# CONFIGURACIÓN DE PNPM/NPM - SEGURIDAD Y RENDIMIENTO
# ==============================================================================
# Este archivo configura el comportamiento de pnpm al instalar dependencias.
# Las opciones de seguridad aquí son críticas para producción.
# ==============================================================================

# === SEGURIDAD ===

# Evita que paquetes ejecuten scripts arbitrarios durante la instalación
# Los scripts de postinstall son un vector común de ataques en supply chain
# Si un paquete legítimo necesita postinstall, añádelo a la allowlist abajo
ignore-scripts=true

# Lista de paquetes permitidos para ejecutar scripts de instalación
# Solo añade paquetes que realmente necesiten ejecutar scripts
# Ejemplo: esbuild necesita descargar el binario correcto para tu SO
# onlyBuiltDependencies = ["esbuild", "@swc/core", "sharp"]

# Fuerza el uso de HTTPS para todas las conexiones al registry
# Previene ataques man-in-the-middle
strict-ssl=true

# No permite instalar paquetes con dependencias peer no satisfechas
# Ayuda a detectar problemas de compatibilidad antes de que lleguen a producción
strict-peer-dependencies=false

# Verifica integridad de paquetes con checksums
# Si un paquete fue modificado maliciosamente, fallará la instalación
# resolution-mode=highest

# === RENDIMIENTO ===

# Usa links simbólicos para compartir dependencias entre proyectos
# Ahorra espacio en disco y acelera instalaciones
symlink=true

# Número de conexiones paralelas al registry
# Ajusta según tu conexión de internet
network-concurrency=16

# Usa cache agresivo para instalaciones más rápidas
prefer-offline=true

# === MONOREPO ===

# Instala dependencias de workspace primero desde el monorepo
link-workspace-packages=true

# Sube dependencias compartidas a la raíz del workspace
hoist=true

# Patrones de dependencias que NO deben subirse (quedan en node_modules local)
# Útil cuando diferentes apps necesitan diferentes versiones
public-hoist-pattern[]='*types*'
public-hoist-pattern[]='*eslint*'
public-hoist-pattern[]='*biome*'

# === REGISTRY ===

# Registry oficial de npm (cambiar si usas Verdaccio, Nexus, etc.)
registry=https://registry.npmjs.org/

# Timeout para conexiones lentas
fetch-timeout=60000

# === LOGS ===

# Nivel de detalle en logs (debug, info, warn, error)
loglevel=warn
