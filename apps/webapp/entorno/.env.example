# ==============================================================================
# PLANTILLA DE VARIABLES DE ENTORNO
# ==============================================================================
# Copia este archivo a .env.{modo} donde modo puede ser:
#   - desarrollo (pnpm dev)
#   - produccion (pnpm build)
#   - staging (build de pruebas)
#
# Ejemplo: cp .env.example .env.desarrollo
# ==============================================================================

# === SERVIDOR ===
VITE_PROTOCOLO="http"           # http o https
VITE_HOST="localhost"           # Dominio o IP
VITE_PUERTO="4200"              # Puerto del servidor de desarrollo
VITE_BASE_PATH="/"              # Path base (ej: "/app/" si no está en raíz)

# === APLICACIÓN ===
VITE_NOMBRE_APP="MiApp"         # Nombre mostrado en la UI
VITE_VERSION="0.0.0"            # Versión semántica

# === BACKEND/API ===
VITE_API_URL=""                 # URL completa del API (ej: https://api.ejemplo.com)
VITE_API_TIMEOUT="10000"        # Timeout en milisegundos

# === DEBUG ===
VITE_DEBUG="false"              # "true" para logs extra
VITE_ENABLE_DEVTOOLS="false"    # "true" para React Query DevTools

# === ANALYTICS (opcional) ===
# VITE_ANALYTICS_ID=""          # ID de Google Analytics, Plausible, etc.
