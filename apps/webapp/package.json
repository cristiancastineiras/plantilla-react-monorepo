{
	"name": "webapp",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite --mode desarrollo",
		"build": "tsc --noEmit && vite build --mode produccion",
		"build:dev": "vite build --mode desarrollo",
		"preview": "vite preview --mode produccion",
		"typecheck": "tsc --noEmit",
		"lint": "oxlint src/",
		"lint:fix": "oxlint --fix src/",
		"format": "oxfmt src/",
		"format:check": "oxfmt --check src/",
		"clean": "rimraf dist .turbo"
	}
}
