{
	"$schema": "https://biomejs.dev/schemas/2.0.0/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true,
		"root": "."
	},
	"files": {
		"ignoreUnknown": true,
		"ignore": [
			"**/node_modules/**",
			"**/dist/**",
			"**/.turbo/**",
			"**/coverage/**",
			"**/*.min.js",
			"**/pnpm-lock.yaml"
		],
		"maxSize": 1048576
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"indentWidth": 2,
		"lineWidth": 100,
		"lineEnding": "lf",
		"formatWithErrors": false
	},
	"organizeImports": {
		"enabled": true
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"complexity": {
				"noForEach": "warn",
				"noUselessSwitchCase": "error",
				"useSimplifiedLogicExpression": "warn"
			},
			"correctness": {
				"noUndeclaredVariables": "error",
				"noUnusedImports": "error",
				"noUnusedVariables": "warn",
				"noVoidTypeReturn": "error"
			},
			"performance": {
				"noBarrelFile": "warn",
				"noDelete": "warn"
			},
			"security": {
				"noDangerouslySetInnerHtml": "error"
			},
			"style": {
				"useConst": "error",
				"useTemplate": "error",
				"noUselessElse": "error",
				"useShorthandArrayType": "error",
				"useImportType": "error"
			},
			"suspicious": {
				"noConsoleLog": "warn",
				"noDebugger": "error",
				"noDuplicateCase": "error",
				"noExplicitAny": "warn",
				"noConfusingVoidType": "error"
			},
			"a11y": {
				"useAltText": "error",
				"useAnchorContent": "error",
				"noLabelWithoutControl": "error"
			}
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double",
			"semicolons": "asNeeded",
			"trailingCommas": "all",
			"arrowParentheses": "asNeeded"
		},
		"parser": {
			"unsafeParameterDecoratorsEnabled": true
		}
	},
	"json": {
		"formatter": {
			"trailingCommas": "none"
		},
		"parser": {
			"allowComments": true,
			"allowTrailingCommas": true
		}
	},
	"overrides": [
		{
			"include": [
				"*.config.js",
				"*.config.ts"
			],
			"linter": {
				"rules": {
					"correctness": {
						"noNodejsModules": "off"
					}
				}
			}
		},
		{
			"include": [
				"**/*.test.ts",
				"**/*.test.tsx",
				"**/*.spec.ts"
			],
			"linter": {
				"rules": {
					"suspicious": {
						"noConsoleLog": "off",
						"noExplicitAny": "off"
					}
				}
			}
		}
	]
}